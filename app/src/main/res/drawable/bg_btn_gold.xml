<?xml version="1.0" encoding="utf-8"?>
<!-- bg_btn_gold.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#B8821E"
                android:endColor="#D4A438"
                android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#C9922E"
                android:endColor="#E8B84B"
                android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</selector>