<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2EAD8">

    <!-- HEADER / APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C1208"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1C1208"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#C9A84C"
            app:title="BIBLIOTECA DIGITAL"
            app:titleTextColor="#C9A84C" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- MAIN CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- TÍTULO DA SALA -->
            <TextView
                android:id="@+id/tvSalaTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sala A, Andar 1"
                android:textColor="#3B2A0E"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- SUBTÍTULO CAPACIDADE -->
            <TextView
                android:id="@+id/tvCapacidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cap. 6 pessoas"
                android:textColor="#8C6D3F"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <!-- BADGE LIVRE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_badge_livre"
                android:paddingHorizontal="16dp"
                android:paddingVertical="5dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVRE"
                    android:textColor="#7A5A1E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- DIVISOR -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9C9A8"
                android:layout_marginBottom="16dp" />

            <!-- TÍTULO SEÇÃO HORÁRIOS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Horários Disponíveis"
                android:textColor="#3B2A0E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:paddingBottom="12dp" />

            <!-- CARD HORÁRIO 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EDE0C4"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        app:tint="#C9A84C"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1º Turno"
                            android:textColor="#8C6D3F"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="07:30 às 09:10"
                            android:textColor="#3B2A0E"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1h40"
                        android:textColor="#7A5A1E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_duration_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD HORÁRIO 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EDE0C4"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        app:tint="#C9A84C"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2º Turno"
                            android:textColor="#8C6D3F"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09:30 às 11:10"
                            android:textColor="#3B2A0E"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1h40"
                        android:textColor="#7A5A1E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_duration_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD HORÁRIO 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EDE0C4"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        app:tint="#C9A84C"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3º Turno"
                            android:textColor="#8C6D3F"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11:20 às 13:00"
                            android:textColor="#3B2A0E"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1h40"
                        android:textColor="#7A5A1E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_duration_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD HORÁRIO 4 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EDE0C4"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        app:tint="#C9A84C"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4º Turno"
                            android:textColor="#8C6D3F"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="13:30 às 15:10"
                            android:textColor="#3B2A0E"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1h40"
                        android:textColor="#7A5A1E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_duration_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD HORÁRIO 5 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EDE0C4"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        app:tint="#C9A84C"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5º Turno"
                            android:textColor="#8C6D3F"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15:30 às 17:30"
                            android:textColor="#3B2A0E"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2h00"
                        android:textColor="#7A5A1E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_duration_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- DIVISOR -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:background="#2A2A2A" />

    <!-- ── BOTTOM NAV SEM LABELS ── -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#121212"
        android:orientation="horizontal"
        android:elevation="8dp">

        <!-- Menu -->
        <LinearLayout
            android:id="@+id/navMenu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconChat"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chat"
                android:contentDescription="Chat"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Início"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <!-- Reservas -->
        <LinearLayout
            android:id="@+id/navReservas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconReservas"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="Reservas"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <!-- Salas -->
        <LinearLayout
            android:id="@+id/navSalas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconSalas"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_signpost"
                android:contentDescription="Salas"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconPerfil"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Perfil"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>