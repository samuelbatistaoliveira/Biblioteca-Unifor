<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavigation"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="#1A1A2E"
    android:baselineAligned="false"
    android:elevation="8dp"
    android:gravity="center">

    <!-- Gerenciamento (hambúrguer) -->
    <LinearLayout
        android:id="@+id/navChat"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:id="@+id/navChatBg"
            android:layout_width="56dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconChat"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu_book"
                app:tint="#FFFFFF"
                android:contentDescription="Gerenciar" />

        </LinearLayout>

    </LinearLayout>

    <!-- Home -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:id="@+id/navHomeBg"
            android:layout_width="56dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="#FFFFFF"
                android:contentDescription="Home" />

        </LinearLayout>

    </LinearLayout>

    <!-- Calendário -->
    <LinearLayout
        android:id="@+id/navCalendar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:id="@+id/navCalendarBg"
            android:layout_width="56dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconCalendar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_calendar"
                app:tint="#FFFFFF"
                android:contentDescription="Calendário" />

        </LinearLayout>

    </LinearLayout>

    <!-- Categorias -->
    <LinearLayout
        android:id="@+id/navCategories"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:id="@+id/navCategoriesBg"
            android:layout_width="56dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconCategories"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_signpost"
                app:tint="#FFFFFF"
                android:contentDescription="Categorias" />

        </LinearLayout>

    </LinearLayout>

    <!-- Perfil -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:id="@+id/navProfileBg"
            android:layout_width="56dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                app:tint="#FFFFFF"
                android:contentDescription="Perfil" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>