<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="5dp">

    <!-- Capa -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Imagem da capa -->
                <ImageView
                    android:id="@+id/imgCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Capa do livro"
                    tools:src="@tools:sample/backgrounds/scenic" />

                <!-- Gradiente navy na parte inferior -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_book_overlay" />

                <!-- Badge de avaliação (visível via código) -->
                <LinearLayout
                    android:id="@+id/badgeRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="5dp"
                    android:background="@drawable/bg_badge_gold"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="#D4AF37"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:textColor="#D4AF37"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        tools:text="4.5" />

                </LinearLayout>

                <!-- Badge "Novo" (visível via código) -->
                <TextView
                    android:id="@+id/badgeNew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="5dp"
                    android:background="@drawable/bg_badge_new"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="Novo"
                    android:textColor="#2E7D32"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Título sobre a capa -->
                <TextView
                    android:id="@+id/tvCoverTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:padding="6dp"
                    android:textColor="#F8F4EE"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="Título do Livro" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Nome abaixo da capa -->
    <TextView
        android:id="@+id/tvBookName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:textColor="#0D1B2A"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Nome do Livro" />

</LinearLayout>