<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2C1A0E"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="40dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnVoltar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Voltar"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="#C8A84B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="BIBLIOTECA DIGITAL"
                    android:textColor="#C8A84B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Registro de Devolução"
                android:textColor="#F5F0E8"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Preencha os dados para registrar a devolução"
                android:textColor="#A89070"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Banner dourado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#C8A84B"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirme as informações do usuário e do livro"
                android:textColor="#2C1A0E"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SEÇÃO 1: Dados do registro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DADOS DO REGISTRO"
                android:textColor="#2C1A0E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C8A84B"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do Usuário"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNome"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_border"
                android:hint="Digite o nome completo"
                android:textColorHint="#B0A090"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título do Livro"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etLivro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_border"
                android:hint="Digite o título do livro"
                android:textColorHint="#B0A090"
                android:inputType="textCapWords"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data de Devolução"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etData"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_border"
                android:hint="DD/MM/AAAA"
                android:textColorHint="#B0A090"
                android:inputType="datetime"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#2C1A0E"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- SEÇÃO 2: Verificações -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFICAÇÕES"
                android:textColor="#2C1A0E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C8A84B"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Livro devolvido está no prazo?"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/rgPrazo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbPrazoSim"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Sim"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbPrazoNao"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Não"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8E0D0"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Multa será aplicada?"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/rgMulta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbMultaSim"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Sim"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbMultaNao"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Não"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8E0D0"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Multa a ser cobrada"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_border_accent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#C8A84B"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="R$"
                    android:textColor="#2C1A0E"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etMulta"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="0,00"
                    android:textColorHint="#B0A090"
                    android:inputType="numberDecimal"
                    android:paddingStart="12dp"
                    android:textColor="#2C1A0E"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- BOTÃO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp">

            <!-- ✅ MaterialButton com backgroundTint null remove o roxo -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAprovar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/btn_aprovar"
                android:text="APROVAR DEVOLUÇÃO"
                android:textColor="#2C1A0E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:text="Verifique todos os campos antes de aprovar"
                android:textColor="#A89070"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>