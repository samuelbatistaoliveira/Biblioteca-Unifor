<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2EAD8">

    <!-- HEADER -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2C1F00"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Detalhes do Livro"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#C8A96E"
            android:background="#2C1F00" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Capa -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#2C1F00">

                <ImageView
                    android:id="@+id/imgBookCover"
                    android:layout_width="150dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_book_cover_shadow"
                    android:clipToOutline="true"
                    tools:src="@tools:sample/backgrounds/scenic" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvBookTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1C1C1C"
                    tools:text="Pai Rico Pai Pobre" />

                <TextView
                    android:id="@+id/tvBookAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="15sp"
                    android:textColor="#C8A96E"
                    android:textStyle="bold"
                    tools:text="Robert T. Kiyosaki" />

                <View
                    android:layout_width="50dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gold_divider" />

                <!-- Cards Ano / Gênero / Estado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ano"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvBookYear"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C1C"
                                android:gravity="center"
                                tools:text="2000" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gênero"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvBookGenre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C1C"
                                android:gravity="center"
                                tools:text="Finanças" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estado"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvBookStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"
                                android:gravity="center"
                                tools:text="Disponível" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Botões Editar e Deletar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditar"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="✏️ Editar"
                        android:textSize="15sp"
                        android:textColor="#1C1C1C"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:backgroundTint="#FFFFFF"
                        app:cornerRadius="14dp"
                        app:strokeColor="#C8A96E"
                        app:strokeWidth="1.5dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeletar"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="🗑️ Deletar"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:backgroundTint="#C62828"
                        app:cornerRadius="14dp" />

                </LinearLayout>

                <!-- ✅ Botão Localizar Livro -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLocalizar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="📍 Localizar Livro"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null"
                    android:background="@drawable/button_gold_background"
                    app:cornerRadius="14dp" />

                <!-- Card aviso -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1FC8A96E"
                    app:strokeColor="#66C8A96E"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="top">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_info"
                            app:tint="#C8A96E"
                            android:contentDescription="Info" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="A exclusão é permanente e não pode ser desfeita."
                            android:textSize="13sp"
                            android:textColor="#7A6A55"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <!-- BOTTOM NAV -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/bottom_nav_admin"
        android:layout_width="match_parent"
        android:layout_height="64dp" />

</LinearLayout>