<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F4EE">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Detalhes do Livro"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#FFFFFF"
            android:background="#000000" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Conteúdo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Capa do livro -->
        <ImageView
            android:id="@+id/imgBookCover"
            android:layout_width="140dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="24dp" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvBookTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Autor -->
        <TextView
            android:id="@+id/tvBookAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#555555"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Ano -->
        <TextView
            android:id="@+id/tvBookYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <!-- Gênero -->
        <TextView
            android:id="@+id/tvBookGenre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvBookStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Botão -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdicionarLivro"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Adicionar Livro"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F8F4EE"
            app:backgroundTint="#0D1B2A"
            app:cornerRadius="14dp"
            app:elevation="4dp" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/bottom_nav_admin"
        android:layout_width="match_parent"
        android:layout_height="64dp" />

</LinearLayout>