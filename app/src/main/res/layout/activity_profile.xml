<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- ── BOTTOM NAVIGATION FIXA ── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#1A1A1A"
        android:elevation="20dp"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:itemActiveIndicatorStyle="@null"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_nav_menu" />

    <!-- ── SCROLL DO CONTEÚDO ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FDF8F2"
        android:paddingBottom="64dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp"
            android:focusable="false">

            <!-- ── HEADER ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:focusable="false">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:text="Meu Perfil"
                    android:textColor="#121212"
                    android:textIsSelectable="false"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:focusable="false">

                    <FrameLayout
                        android:id="@+id/btnMultas"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/circle_gold_bg"
                        android:focusable="false">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="$"
                            android:textColor="#121212"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btnEditarPerfil"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/circle_dark_bg"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_edit"
                            android:focusable="false"
                            app:tint="#C8A96E" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btnConfiguracoes"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_dark_bg"
                        android:focusable="false">
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:focusable="false"
                            android:src="@drawable/ic_settings"
                            app:tint="#C8A96E" />
                    </FrameLayout>

                </LinearLayout>
            </RelativeLayout>

            <!-- ── CARD DE USUÁRIO ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:focusable="false"
                app:cardBackgroundColor="#F4EDE3"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical"
                    android:focusable="false">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:focusable="false">
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@drawable/defaultavatar"
                            android:focusable="false"
                            app:civ_border_color="#C8A96E"
                            app:civ_border_width="2.5dp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:focusable="false">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carol Oliveira"
                            android:textColor="#2C1F0E"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                        <TextView
                            android:id="@+id/tvUserEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="carololiveira@gmail.com"
                            android:textColor="#7A6A55"
                            android:textSize="12sp"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/badge_gold_bg"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="Membro Ativo"
                            android:textColor="#121212"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ESTATÍSTICAS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:focusable="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:focusable="false"
                    app:cardBackgroundColor="#F4EDE3"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp"
                        android:focusable="false">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="#C8A96E"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alugados"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:focusable="false"
                    app:cardBackgroundColor="#F4EDE3"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp"
                        android:focusable="false">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textColor="#C8A96E"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Devolvidos"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:focusable="false"
                    app:cardBackgroundColor="#F4EDE3"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp"
                        android:focusable="false">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$0"
                            android:textColor="#C0392B"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Multas"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"
                            android:textIsSelectable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── SEÇÃO: LIVROS ALUGADOS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:focusable="false"
                android:text="Livros que você alugou"
                android:textColor="#121212"
                android:textIsSelectable="false"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- ── ITEM 1 - EM ATRASO ── -->
            <!-- ── ITEM 1 - EM ATRASO ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:focusable="false"
                app:cardBackgroundColor="#F4EDE3"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:focusable="false">

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="90dp"
                        android:focusable="false"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp">
                        <ImageView
                            android:id="@+id/ivBook1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/capaverde"
                            android:scaleType="centerCrop"
                            android:focusable="false" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:gravity="center_vertical"
                        android:focusable="false">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biblioteca da Meia Noite"
                            android:textColor="#2C1F0E"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp"
                            android:focusable="false">
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_calendar"
                                android:focusable="false"
                                app:tint="#888888" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="4dp"
                                android:text="Entrega: 17/03/2026"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                android:textIsSelectable="false"
                                android:focusable="false" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/badge_red_bg"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="⚠ 10 dias em atraso"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivArrowBook1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_arrow_right"
                        android:focusable="false"
                        android:contentDescription="Ver multas"
                        app:tint="#555555" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ITEM 2 - A TEMPO ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:focusable="false"
                app:cardBackgroundColor="#F4EDE3"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:focusable="false">

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="90dp"
                        android:focusable="false"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp">
                        <ImageView
                            android:id="@+id/ivBook2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/assimqueacaba"
                            android:scaleType="centerCrop"
                            android:focusable="false" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:gravity="center_vertical"
                        android:focusable="false">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="É assim que acaba."
                            android:textColor="#2C1F0E"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp"
                            android:focusable="false">
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_calendar"
                                android:focusable="false"
                                app:tint="#7A6A55" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="4dp"
                                android:text="Entrega: 17/03/2026"
                                android:textColor="#7A6A55"
                                android:textSize="12sp"
                                android:textIsSelectable="false"
                                android:focusable="false" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/badge_green_bg"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="✓ 4 dias até a entrega"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textIsSelectable="false"
                            android:focusable="false" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── AVISO DE MULTA ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:focusable="false"
                app:cardBackgroundColor="#EDE0CE"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:focusable="false">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:text="ⓘ"
                        android:textColor="#E05252"
                        android:textSize="18sp"
                        android:textIsSelectable="false"
                        android:focusable="false" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="10dp"
                        android:text="Você possui livros em atraso. Entregas após o prazo geram multas!"
                        android:textColor="#E05252"
                        android:textSize="12sp"
                        android:textIsSelectable="false"
                        android:focusable="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>