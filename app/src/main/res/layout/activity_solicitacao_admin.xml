<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2C1A0E"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="40dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnVoltar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Voltar"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#C8A84B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="BIBLIOTECA DIGITAL"
                    android:textColor="#C8A84B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Aprovar Solicitação"
                android:textColor="#F5F0E8"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Preencha os dados para aprovar a solicitação"
                android:textColor="#A89070"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- BANNER DOURADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#C8A84B"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirme as informações do aluno e do livro"
                android:textColor="#2C1A0E"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SEÇÃO 1: Dados da Solicitação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DADOS DA SOLICITAÇÃO"
                android:textColor="#2C1A0E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C8A84B"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do Aluno"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNome"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_border"
                android:hint="Digite o nome completo"
                android:textColorHint="#B0A090"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título do Livro"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etLivro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_border"
                android:hint="Digite o título do livro"
                android:textColorHint="#B0A090"
                android:inputType="textCapWords"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data de Entrega Prevista"
                android:textColor="#6B4C2A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etData"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_border"
                android:hint="DD/MM/AAAA"
                android:textColorHint="#B0A090"
                android:inputType="datetime"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#2C1A0E"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- SEÇÃO 2: Histórico do Aluno -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="HISTÓRICO DO ALUNO"
                android:textColor="#2C1A0E"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C8A84B"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_aprovado"
                    android:layout_marginEnd="10dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Livro 1: Entregue no prazo"
                    android:textColor="#2C1A0E"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_pendente"
                    android:layout_marginEnd="10dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Livro 2: Alugado até dia 14/04"
                    android:textColor="#2C1A0E"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_recusado"
                    android:layout_marginEnd="10dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Livro 3: Atrasado"
                    android:textColor="#2C1A0E"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_aprovado"
                    android:layout_marginEnd="10dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Livro 4: Entregue no prazo"
                    android:textColor="#2C1A0E"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- SEÇÃO 3: Verificações -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFICAÇÕES"
                android:textColor="#2C1A0E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C8A84B"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aluno está dentro do prazo?"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/rgPrazo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbPrazoSim"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Sim"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbPrazoNao"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Não"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8E0D0"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aluno possui pendências?"
                android:textColor="#2C1A0E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/rgPendencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbPendenciaSim"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Sim"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rbPendenciaNao"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_unselected"
                    android:gravity="center"
                    app:buttonTint="#C8A84B"
                    android:text="Não"
                    android:textColor="#2C1A0E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </RadioGroup>

        </LinearLayout>

        <!-- BOTÕES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp">

            <!-- ✅ app:backgroundTint="@null" remove o roxo do Material -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAprovar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/btn_aprovar"
                android:gravity="center"
                android:text="Aprovar Solicitação"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecusar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_cancelar"
                android:gravity="center"
                android:text="Cancelar"
                android:textColor="#2C1A0E"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:text="Verifique todos os campos antes de confirmar"
                android:textColor="#A89070"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>