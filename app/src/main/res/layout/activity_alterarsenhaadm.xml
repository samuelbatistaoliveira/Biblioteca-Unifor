<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar / Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#F5F0E8"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/btnVoltar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voltar"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#C49A22" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="Alterar Senha"
                android:textColor="#2C2517"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Divider sutil -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8DEC8" />

        <!-- Ícone decorativo central -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="25dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/circle_gold_bg" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="Cadeado"
                    android:src="@drawable/ic_lock"
                    app:tint="#FFFFFF" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.04"
                android:text="Segurança da Conta"
                android:textColor="#8B6914"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Card principal com os campos -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Linha decorativa dourada -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="3dp"
                    android:layout_gravity="start"
                    android:layout_marginBottom="20dp"
                    android:background="#C49A22" />

                <!-- Label: Senha Atual -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:text="Senha atual"
                    android:textAllCaps="true"
                    android:textColor="#6B5A2E"
                    android:textSize="12sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <!-- FIX: android:textColorHint (correto) no lugar de hintTextColor -->
                    <EditText
                        android:id="@+id/etSenhaAtual"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:autofillHints="password"
                        android:background="@drawable/input_background"
                        android:hint="Digite sua senha atual"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textColor="#2C2517"
                        android:textColorHint="#9E8C6A"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivToggleSenhaAtual"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical|end"
                        android:contentDescription="Mostrar senha atual"
                        android:padding="12dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="#C49A22" />

                </FrameLayout>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="20dp"
                    android:background="#F0E8D8" />

                <!-- Label: Nova Senha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:text="Nova senha"
                    android:textAllCaps="true"
                    android:textColor="#6B5A2E"
                    android:textSize="12sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">

                    <!-- FIX: android:textColorHint -->
                    <EditText
                        android:id="@+id/etNovaSenha"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:autofillHints="newPassword"
                        android:background="@drawable/input_background"
                        android:hint="Digite a nova senha"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textColor="#2C2517"
                        android:textColorHint="#9E8C6A"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivToggleNovaSenha"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical|end"
                        android:contentDescription="Mostrar nova senha"
                        android:padding="12dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="#C49A22" />

                </FrameLayout>

                <!-- Indicador de força da senha -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <View
                        android:id="@+id/barForca1"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="#E0D5C0" />

                    <View
                        android:id="@+id/barForca2"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="#E0D5C0" />

                    <View
                        android:id="@+id/barForca3"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="#E0D5C0" />

                    <View
                        android:id="@+id/barForca4"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:background="#E0D5C0" />

                </LinearLayout>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="20dp"
                    android:background="#F0E8D8" />

                <!-- Label: Confirmar Nova Senha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:text="Confirmar nova senha"
                    android:textAllCaps="true"
                    android:textColor="#6B5A2E"
                    android:textSize="12sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- FIX: android:textColorHint -->
                    <EditText
                        android:id="@+id/etConfirmarSenha"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:autofillHints="newPassword"
                        android:background="@drawable/input_background"
                        android:hint="Confirme a nova senha"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:textColor="#2C2517"
                        android:textColorHint="#9E8C6A"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivToggleConfirmar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical|end"
                        android:contentDescription="Mostrar confirmação de senha"
                        android:padding="12dp"
                        android:src="@drawable/ic_visibility_off"
                        app:tint="#C49A22" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvErroSenha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:drawablePadding="4dp"
                    android:text="As senhas não coincidem"
                    android:textColor="#D32F2F"
                    android:textSize="12sp"
                    android:visibility="gone"
                    app:drawableStartCompat="@drawable/ic_error"
                    app:drawableTint="#D32F2F" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Dicas de segurança -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFF8E7"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Info"
                        android:src="@drawable/ic_info"
                        app:tint="#C49A22" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Dicas para uma senha segura"
                        android:textColor="#8B6914"
                        android:textSize="13sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/circle_gold_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mínimo de 8 caracteres"
                        android:textColor="#6B5A2E"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/circle_gold_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Combine letras maiúsculas e minúsculas"
                        android:textColor="#6B5A2E"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/circle_gold_small" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Use números e caracteres especiais"
                        android:textColor="#6B5A2E"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSalvarAlteracoes"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_gold_background"
            android:elevation="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="Salvar Alterações"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- Botão Cancelar -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/button_outline_gold"
            android:fontFamily="sans-serif-medium"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#2D2D2D"
            android:textSize="16sp" />
    </LinearLayout>

</ScrollView>